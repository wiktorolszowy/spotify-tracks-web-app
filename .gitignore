# ---------------------------------------------------------------------------
# Data hygiene: never commit data. The app's data lives OUTSIDE this repo, in
# /home/wo222/spotify-tracks-web-app-data. These patterns are a second line of
# defence in case a data file ever lands inside the repo tree.
# ---------------------------------------------------------------------------
*.csv
*.tsv
*.parquet
*.feather
*.arrow
*.orc
*.avro
*.h5
*.hdf5
*.pkl
*.pickle
*.npy
*.npz
*.xls
*.xlsx
*.xlsm
*.db
*.sqlite
*.sqlite3
*.json.gz
*.parquet.gz
data/
datasets/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg

# Virtual environments / uv
.venv/
venv/
env/
.uv/

# Test / coverage / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/

# Secrets / env
.env
.env.*
*.pem
*.key
secrets.*

# ---------------------------------------------------------------------------
# Editors / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Jupyter
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
